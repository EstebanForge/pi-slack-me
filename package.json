{
  "name": "@estebanforge/pi-slack-me",
  "version": "1.0.0",
  "description": "Slack read tools for Pi that act as YOU, not as a bot. Adds 5 LLM-callable tools (slack_*) that read channels, threads, DMs, and search results using a Slack USER token (xoxp-). No bot to invite, no footprint in the workspace - the app inherits your own membership and access. Read-only by design.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "slack",
    "slack-api",
    "read-only",
    "user-token",
    "coding-agent"
  ],
  "license": "MIT",
  "author": {
    "name": "EstebanForge",
    "email": "esteban@attitude.cl",
    "url": "https://actitud.xyz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EstebanForge/pi-slack-me.git"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "extensions",
    "lib",
    "tests",
    "vitest.config.ts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/node": "^22.0.0",
    "typebox": "^1.3.4",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  }
}
